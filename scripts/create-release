#!/bin/bash
# ==============================================================================
# Promote a release from the current branch to the next branch:
#   alpha  → beta
#   beta   → main (stable)
#
# This script:
# 1. Validates it is run from the alpha or beta branch with a clean working tree
# 2. Updates config.yaml and repository.yaml for the target branch
# 3. Commits changes and merges the current branch into the target branch
# 4. Reverts source-branch-specific settings on the target branch
# 5. Pushes both branches
# 6. Switches back to the source branch and reverts config/repo changes
# ==============================================================================
set -euo pipefail

cd "$(cd "$(dirname "$0")/.." ; pwd)"

readonly ADDON_DIR="sigenergy2mqtt"
readonly CONFIG="${ADDON_DIR}/config.yaml"
readonly REPO_YAML="repository.yaml"

# --- Determine promotion path ---

source_branch=$(git branch --show-current)

case "$source_branch" in
  alpha) target_branch="beta" ;;
  beta)  target_branch="main" ;;
  *)
    echo "ERROR: This script must be run from the alpha or beta branch (currently on '$source_branch')."
    exit 1
    ;;
esac

# --- Validate working tree ---

if [[ -n "$(git status --porcelain)" ]]; then
  echo "ERROR: Working tree is not clean. Please commit or stash your changes first."
  exit 1
fi

echo ""
echo "=== Release Summary ==="
echo "  Branch: ${source_branch} → ${target_branch}"
echo "======================="
echo ""

# --- Update files on source branch for target branch ---

echo "Updating config.yaml for target branch (${target_branch})..."

if [[ "$source_branch" == "alpha" ]]; then
  # Promote alpha → beta
  # config.yaml: name  →  sigenergy2mqtt (beta)
  sed -i 's/^name: .*$/name: sigenergy2mqtt (beta)/' "$CONFIG"
  # config.yaml: url  /tree/alpha/ → /tree/beta/
  sed -i 's|/tree/alpha/|/tree/beta/|g' "$CONFIG"
  # config.yaml: delete stage key (beta has no stage key)
  sed -i '/^stage:/d' "$CONFIG"

elif [[ "$source_branch" == "beta" ]]; then
  # Promote beta → main
  # config.yaml: name  →  sigenergy2mqtt
  sed -i 's/^name: .*$/name: sigenergy2mqtt/' "$CONFIG"
  # config.yaml: url  /tree/beta/ → /tree/main/
  sed -i 's|/tree/beta/|/tree/main/|g' "$CONFIG"
  # config.yaml: delete stage key (main has no stage key)
  sed -i '/^stage:/d' "$CONFIG"
fi

echo "Committing changes to ${source_branch} branch..."
git add "$CONFIG"
git commit -m "chore(release): promote ${source_branch} to ${target_branch}"

# --- Merge to target branch ---

echo "Switching to ${target_branch} and merging ${source_branch}..."
git checkout "$target_branch"
git merge "$source_branch" -m "Merge ${source_branch} into ${target_branch}"

# --- Revert source-branch-specific settings on target branch ---

echo "Updating repository.yaml for ${target_branch}..."

if [[ "$source_branch" == "alpha" ]]; then
  # On beta branch after merge:
  # repository.yaml: "(Alpha)" → "(Beta)"
  sed -i 's/ (Alpha)/ (Beta)/' "$REPO_YAML"
  # repository.yaml: "#alpha" → "#beta"
  sed -i 's/#alpha/#beta/' "$REPO_YAML"

elif [[ "$source_branch" == "beta" ]]; then
  # On main branch after merge:
  # repository.yaml: remove " (Beta)" and "#beta"
  sed -i 's/ (Beta)//' "$REPO_YAML"
  sed -i 's/#beta//' "$REPO_YAML"
fi

git add "$REPO_YAML"
git commit -m "chore(release): update repository for ${target_branch}"

# --- Push ---

echo ""
echo "=== Ready to push ==="
echo "  ${source_branch}: promotion commit"
echo "  ${target_branch}: merged release"
echo ""
echo "Pushing ${target_branch} will trigger the Home Assistant add-on builder workflow."
echo ""
read -rp "Push both branches? [Y/n] " confirm
confirm="${confirm:-Y}"

if [[ "$confirm" =~ ^[Yy]$ ]]; then
  echo "Pushing ${target_branch}..."
  git push origin "$target_branch"
  echo "Pushing ${source_branch}..."
  git push origin "$source_branch"
  echo ""
  echo "Done! ${source_branch} has been promoted to ${target_branch}."
else
  echo ""
  echo "Push cancelled. Both branches have been updated locally."
  echo "When ready, run:"
  echo "  git push origin ${target_branch}"
  echo "  git push origin ${source_branch}"
fi

# --- Switch back to source branch and revert source-specific settings ---

echo "Switching back to ${source_branch} branch..."
git checkout "$source_branch"

echo "Reverting target-branch changes on ${source_branch}..."

if [[ "$source_branch" == "alpha" ]]; then
  # Revert config.yaml back to alpha state
  # name: sigenergy2mqtt (alpha)
  sed -i 's/^name: .*$/name: sigenergy2mqtt (alpha)/' "$CONFIG"
  # url: /tree/beta/ → /tree/alpha/
  sed -i 's|/tree/beta/|/tree/alpha/|g' "$CONFIG"
  # stage: restore experimental (insert after 'slug:' line or before 'url:')
  if ! grep -q '^stage:' "$CONFIG"; then
    sed -i '/^slug:/a stage: experimental' "$CONFIG"
  fi

elif [[ "$source_branch" == "beta" ]]; then
  # Revert config.yaml back to beta state
  # name: sigenergy2mqtt (beta)
  sed -i 's/^name: .*$/name: sigenergy2mqtt (beta)/' "$CONFIG"
  # url: /tree/main/ → /tree/beta/
  sed -i 's|/tree/main/|/tree/beta/|g' "$CONFIG"
  # No stage key on beta — ensure it's absent
  sed -i '/^stage:/d' "$CONFIG"
fi

# Ensure stage is set to experimental for alpha and beta
if grep -q '^stage:' "$CONFIG"; then
  sed -i '/^slug:/a stage: experimental' "$CONFIG"
else
  sed -i '/^slug:/a stage: experimental' "$CONFIG"
fi

git add "$CONFIG"
git commit -m "chore(release): restore ${source_branch}-specific settings"

echo ""
echo "Done. You are back on the ${source_branch} branch."
