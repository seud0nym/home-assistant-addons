#!/bin/bash

declare -A SIGENERGY2MQTT_PARAMETERS    # associative array for options
declare -A LIST_OPTS                    # options that accept multiple values
declare -A VALID_CLI_OPTS               # valid options allow-list  
declare -A VALID_ENV_VAR                # valid environment variables allow-list  

for opt in $(cat $(dirname $0)/sigenergy2mqtt.cli.options); do
    VALID_CLI_OPTS[$opt]=1
done
for env in $(cat $(dirname $0)/sigenergy2mqtt.env.vars); do
    VALID_ENV_VAR[$env]=1
done

for opt in influxdb-exclude influxdb-include modbus-accharger-device-id modbus-dccharger-device-id modbus-inverter-device-id; do
    if [[ -n "${VALID_CLI_OPTS[$opt]}" ]]; then
        LIST_OPTS[$opt]=1
    else
        echo "ERROR: Attempted to declare unknown option '$opt' as a list option"
        exit 1
    fi
done

# Logging for clean-option test
if [ -n "$TEST_NAME" ]; then
  echo "SIGENERGY2MQTT_CALL: $@" >> /tmp/${TEST_NAME}_calls.log
fi

# Process CLI options
while [[ $# -gt 0 ]]; do
    arg="$1"

    case "$arg" in
        --*=*)  
            # --option=value
            key="${arg%%=*}"
            key="${key#--}"
            value="${arg#*=}"
            
            if [[ -z "${VALID_CLI_OPTS[$key]}" ]]; then
                echo "ERROR: Unknown argument: $key"
                exit 1
            fi

            if [[ -n "${LIST_OPTS[$key]}" && -n "${SIGENERGY2MQTT_PARAMETERS[$key]}" ]]; then
                SIGENERGY2MQTT_PARAMETERS["$key"]="${SIGENERGY2MQTT_PARAMETERS[$key]}|$value"
            else
                SIGENERGY2MQTT_PARAMETERS["$key"]="$value"
            fi
            shift
            ;;

        --*)
            # --option or --option value(s)
            key="${arg#--}"
            shift

            if [[ -z "${VALID_CLI_OPTS[$key]}" ]]; then
                echo "ERROR: Unknown argument: $key"
                exit 1
            fi

            # If next token is another option or nothing, treat as boolean flag
            if [[ $# -eq 0 || "$1" == --* ]]; then
                SIGENERGY2MQTT_PARAMETERS["$key"]=true
                continue
            fi

            # If this option accepts multiple values, collect until next --option
            if [[ -n "${LIST_OPTS[$key]}" ]]; then
                values=()
                while [[ $# -gt 0 && "$1" != --* ]]; do
                    values+=("$1")
                    shift
                done
                SIGENERGY2MQTT_PARAMETERS["$key"]="${values[*]}"
            else
                # Single value
                SIGENERGY2MQTT_PARAMETERS["$key"]="$1"
                shift
            fi
            ;;

        *)
            echo "ERROR: Unknown argument: $arg"
            exit 1
            ;;
    esac
done

# Process ENV options
while IFS='=' read -r key value; do
    if [[ $key == SIGENERGY2MQTT_* ]]; then
        if [[ -z "${VALID_ENV_VAR[$key]}" ]]; then
            echo "ERROR: Unknown environment variable: $key"
            exit 1
        fi
        SIGENERGY2MQTT_PARAMETERS["$key"]="$value"
    fi
done < <(env)

# Validate parsed options against expected assertions
if [[ -n "${ASSERTIONS_SERIALIZED}" ]]; then
    source ../functions.sh
    validate_params_against_assertions
fi
